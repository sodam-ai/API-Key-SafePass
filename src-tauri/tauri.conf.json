{
  "$schema": "https://raw.githubusercontent.com/nicotineo/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "API Key SafePass",
  "version": "0.1.0",
  "identifier": "com.apikeyvault.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:7845",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "API Key SafePass",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "center": true,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
